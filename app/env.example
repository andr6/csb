# ─── CSB — Chat Shit Bob ──────────────────────────────────────────────────────
# Copy to .env — NEVER commit .env to git.

# ══════════════════════════════════════════════════════════════════════════════
# PROVIDER
# ══════════════════════════════════════════════════════════════════════════════
CONTESTANT_PROVIDER=openrouter
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE

# ══════════════════════════════════════════════════════════════════════════════
# ACTIVE MODELS — comma-separated list of model IDs to enable in the app
# Must match keys in MODEL_CATALOGUE in server.js
# Max recommended: 10 (UI fits 10 cards well)
# ══════════════════════════════════════════════════════════════════════════════
ACTIVE_MODELS=gpt4o,claude,gemini,grok,mistral,llama,deepseek,qwen,nemotron,phi4

# ══════════════════════════════════════════════════════════════════════════════
# MODEL STRINGS — override any default from the catalogue
# Format: provider/model-name or provider/model-name:free
# Full list: https://openrouter.ai/models
# ══════════════════════════════════════════════════════════════════════════════

# ── Active defaults (override as needed) ──────────────────────────────────────
MODEL_GPT4O=openai/gpt-4o
MODEL_CLAUDE=anthropic/claude-sonnet-4-5
MODEL_GEMINI=google/gemma-4-27b-it:free
MODEL_GROK=x-ai/grok-3
MODEL_MISTRAL=mistralai/mistral-large
MODEL_LLAMA=meta-llama/llama-3.3-70b-instruct:free
MODEL_DEEPSEEK=deepseek/deepseek-r1:free
MODEL_QWEN=qwen/qwen3-235b-a22b:free
MODEL_NEMOTRON=nvidia/llama-3.1-nemotron-70b-instruct:free
MODEL_PHI4=microsoft/phi-4:free

# ── Reserve pool — add any to ACTIVE_MODELS above to enable ──────────────────
# MODEL_GPT4O_MINI=openai/gpt-4o-mini
# MODEL_CLAUDE_HAIKU=anthropic/claude-haiku-4-5
# MODEL_GEMINI_PRO=google/gemini-pro-1.5
# MODEL_GEMMA3_27B=google/gemma-3-27b-it:free
# MODEL_GEMMA3_12B=google/gemma-3-12b-it:free
# MODEL_GEMMA3_4B=google/gemma-3-4b-it:free
# MODEL_LLAMA_SCOUT=meta-llama/llama-4-scout:free
# MODEL_LLAMA_MAV=meta-llama/llama-4-maverick:free
# MODEL_MISTRAL_SM=mistralai/mistral-small-3.1:free
# MODEL_MISTRAL_NEMO=mistralai/mistral-nemo:free
# MODEL_QWEN3_30B=qwen/qwen3-30b-a3b:free
# MODEL_QWEN3_8B=qwen/qwen3-8b:free
# MODEL_DSV3=deepseek/deepseek-chat-v3-0324:free
# MODEL_DSR1_70B=deepseek/deepseek-r1-distill-llama-70b:free
# MODEL_GROK2=x-ai/grok-2
# MODEL_O3_MINI=openai/o3-mini
# MODEL_CLAUDE_OPUS=anthropic/claude-opus-4-5
# MODEL_PHI3_MINI=microsoft/phi-3-mini-128k-instruct:free
# MODEL_OLMO3=allenai/olmo-3-32b-think:free
# MODEL_INTERNVL3=opengvlab/internvl3-14b:free
# MODEL_TRINITY=arcee-ai/trinity-large-preview:free
# MODEL_DOLPHIN=cognitivecomputations/dolphin-mistral-24gb:free
# MODEL_TOPPY=undi95/toppy-m-7b:free
# MODEL_ZEPHYR=huggingfaceh4/zephyr-7b-beta:free
# MODEL_MYTHOMAX=gryphe/mythomax-l2-13b:free
# MODEL_GLM4=thudm/glm-4-9b-chat:free
# MODEL_KIMI=moonshotai/kimi-k2-5:free

# ── Optional analytics pricing (USD per contestant call) ─────────────────────
# Use active model IDs, not provider model strings. These numbers feed
# score-per-dollar, spend over time, and budget alerts in /api/analytics.
# MODEL_PRICE_GPT4O_USD=0.02
# MODEL_PRICE_CLAUDE_USD=0.03
# MODEL_PRICE_GEMINI_USD=0.002
# JUDGE_PRICE_USD=0.002
# ANALYTICS_SLICE_BUDGET_USD=25
# ANALYTICS_DAILY_BUDGET_USD=5
# ANALYTICS_MONTHLY_BUDGET_USD=100
# ANALYTICS_POLICY_MIN_RELIABILITY_PCT=90
# ANALYTICS_POLICY_MAX_UNIT_COST_USD=0.50
# ANALYTICS_POLICY_MIN_SCORE_PER_DOLLAR=100
# ANALYTICS_POLICY_MIN_AVG_SCORE=60

# ══════════════════════════════════════════════════════════════════════════════
# JUDGE CONFIG
# ══════════════════════════════════════════════════════════════════════════════
# Options: openrouter | anthropic | openai | gemini | litellm
JUDGE_PROVIDER=gemini
JUDGE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
JUDGE_MODEL=gemini-flash-latest

# Other judge options:
# JUDGE_PROVIDER=openrouter
# JUDGE_MODEL=anthropic/claude-sonnet-4-5
#
# JUDGE_PROVIDER=anthropic
# JUDGE_ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
# JUDGE_MODEL=claude-sonnet-4-5
#
# JUDGE_PROVIDER=openai
# JUDGE_OPENAI_API_KEY=sk-YOUR_KEY_HERE
# JUDGE_MODEL=gpt-4o

# ══════════════════════════════════════════════════════════════════════════════
# SERVER
# ══════════════════════════════════════════════════════════════════════════════
PORT=3000
SITE_URL=https://chatshitbob.com
ALLOWED_ORIGINS=https://chatshitbob.com
HTTP_TIMEOUT_MS=15000
# Use longer contestant timeouts for slower OpenRouter models without slowing judge calls.
# CONTESTANT_TIMEOUT_MS=45000
# JUDGE_TIMEOUT_MS=15000
ANALYTICS_PAGE_PASSWORD=YOUR_ANALYTICS_PASSWORD_HERE

# ══════════════════════════════════════════════════════════════════════════════
# FEATURES
# ══════════════════════════════════════════════════════════════════════════════
# Webhook: POST JSON event when crown changes or reliability drops
# WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL

# Daily challenge: prompt fired automatically via POST /api/challenge
# DAILY_CHALLENGE_PROMPT=Is free will real? One sentence.

# Multi-judge consensus: run judge N times, take median scores (1-5, default 1)
# JUDGE_RUNS=3

# ── Spend circuit breaker (0 / unset = disabled) ────────────────────────────
# Global daily caps — when hit, /api/fire or /api/judge return 503 until midnight UTC.
# Set conservatively to protect your OpenRouter/provider budget.
# Example: 500 fire calls ≈ $5–10/day depending on models
# MAX_DAILY_FIRE_CALLS=500
# MAX_DAILY_JUDGE_CALLS=150

# Page-token HMAC secret — set this to keep tokens valid across pm2 restarts.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# PAGE_TOKEN_SECRET=your_64_char_hex_secret_here
