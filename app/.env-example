# =============================================================================
# CSB — Chat Shit Bob Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# All values are optional unless marked as REQUIRED.
# =============================================================================

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HTTP_TIMEOUT_MS=60000

# ── Allowed Origins (CORS) ────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Auto-expands www variants.
# Example: https://chatshitbob.com,https://www.chatshitbob.com
ALLOWED_ORIGINS=

# ── Site Identity ─────────────────────────────────────────────────────────────
SITE_URL=https://chatshitbob.com

# ── Data Paths ─────────────────────────────────────────────────────────────────
# Override default SQLite and JSON file locations.
# Defaults: data/csb.sqlite, data/leaderboard.json, data/analysis-runs.json
# CSB_DB_PATH=
# CSB_HISTORY_FILE=
# CSB_RUNS_FILE=

# ═══════════════════════════════════════════════════════════════════════════════
#  LLM API KEYS
# ═══════════════════════════════════════════════════════════════════════════════

# Contestant keys (used to call models)
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
LITELLM_API_KEY=

# Judge keys (fallback to contestant keys if not set)
JUDGE_OPENROUTER_API_KEY=
JUDGE_ANTHROPIC_API_KEY=
JUDGE_OPENAI_API_KEY=
JUDGE_GEMINI_API_KEY=

# LiteLLM base URL (default: http://localhost:4000)
LITELLM_BASE_URL=

# ═══════════════════════════════════════════════════════════════════════════════
#  MODEL CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Format: MODEL_<ID>=<provider>/<model-string>
# The ID is what you use in the UI and API. Provider prefix is required.
MODEL_GPT4O=openai/gpt-4o
MODEL_CLAUDE=anthropic/claude-sonnet-4-5
MODEL_GEMINI=google/gemini-1.5-pro

# Which models are active (comma-separated IDs). Leave empty to enable all.
# ACTIVE_MODELS=gpt4o,claude

# Per-model timeout overrides in milliseconds
# MODEL_TIMEOUT_GPT4O=30000

# Per-model pricing for analytics (USD per 1M tokens)
# MODEL_PRICE_GPT4O_USD=5.00
# MODEL_PRICE_CLAUDE_USD=3.00

# Contestant provider (default: openrouter)
CONTESTANT_PROVIDER=openrouter

# Judge provider and model
JUDGE_PROVIDER=anthropic
JUDGE_MODEL=anthropic/claude-sonnet-4-5
JUDGE_TIMEOUT_MS=45000
CONTESTANT_TIMEOUT_MS=60000

# How many times Bob judges each run (1-5, default: 1)
JUDGE_RUNS=1

# Judge pricing for spend estimates
JUDGE_PRICE_USD=

# Daily call circuit breakers (0 = disabled)
# MAX_DAILY_FIRE_CALLS=100
# MAX_DAILY_JUDGE_CALLS=500

# ═══════════════════════════════════════════════════════════════════════════════
#  AUTH & SECURITY
# ═══════════════════════════════════════════════════════════════════════════════

# OTP pepper — change this in production. Used to hash verification codes.
OTP_PEPPER=change-me-to-a-long-random-string

# Password hashing cost (10-16, default: 12)
BCRYPT_ROUNDS=12

# OTP settings
OTP_MAX_ATTEMPTS=5
OTP_EXPIRY_MINUTES=10

# Session lifetime (1-168 hours, default: 24)
SESSION_EXPIRY_HOURS=24

# Account lockout after failed logins (15-120 minutes, default: 30)
ACCOUNT_LOCKOUT_MINUTES=30

# Page token secret — used to gate /api/fire and /api/judge.
# Leave empty to auto-generate a random secret on startup.
# PAGE_TOKEN_SECRET=

# ═══════════════════════════════════════════════════════════════════════════════
#  EMAIL (SMTP) — for OTP and password reset emails
# ═══════════════════════════════════════════════════════════════════════════════

MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@chatshitbob.com

# ═══════════════════════════════════════════════════════════════════════════════
#  SMS — for phone verification
# ═══════════════════════════════════════════════════════════════════════════════

SMS_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
#  OAUTH SIGN-IN (Google, Facebook, Instagram)
# ═══════════════════════════════════════════════════════════════════════════════
#
# To enable OAuth sign-in, fill in the credentials for each provider you want.
# Buttons appear automatically when credentials are present.
# OAUTH_REDIRECT_BASE must be your public HTTPS domain (e.g. https://chatshitbob.com).

OAUTH_REDIRECT_BASE=https://chatshitbob.com

# Google OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook Login
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Instagram Basic Display
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# ═══════════════════════════════════════════════════════════════════════════════
#  ANALYTICS DASHBOARD
# ═══════════════════════════════════════════════════════════════════════════════

# Password for the /analytics page (Basic Auth)
ANALYTICS_PAGE_PASSWORD=

# Budget alerts
# ANALYTICS_SLICE_BUDGET_USD=50
# ANALYTICS_DAILY_BUDGET_USD=200
# ANALYTICS_MONTHLY_BUDGET_USD=5000

# Policy thresholds
# ANALYTICS_POLICY_MIN_RELIABILITY_PCT=90
# ANALYTICS_POLICY_MAX_UNIT_COST_USD=0.50
# ANALYTICS_POLICY_MIN_SCORE_PER_DOLLAR=100
# ANALYTICS_POLICY_MIN_AVG_SCORE=60

# ═══════════════════════════════════════════════════════════════════════════════
#  WEBHOOK
# ═══════════════════════════════════════════════════════════════════════════════

# URL to POST run results to after each judgement
WEBHOOK_URL=

# ═══════════════════════════════════════════════════════════════════════════════
#  DAILY CHALLENGE
# ═══════════════════════════════════════════════════════════════════════════════

# Optional custom prompt for the daily challenge feature
DAILY_CHALLENGE_PROMPT=
